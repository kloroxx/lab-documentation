{# ============================================================ #}
{# Nexus 93240YC-FX2 VPC Pair Configuration Template          #}
{# Replacing: Cisco Nexus 5K                                  #}
{# Template Version: 1.0                                      #}
{# Author: Michael Nesteriak | github.com/kloroxx             #}
{# ============================================================ #}
{# USAGE: python3 generate.py --switch [1|2]                  #}
{# ============================================================ #}

{% if switch_num == 1 %}
{% set sw = switch1 %}
{% set peer = switch2 %}
{% set uplink_pc = uplink.switch1_port_channel %}
{% set uplink_ifaces = uplink.switch1_interfaces %}
{% set hsrp_priority = hsrp.switch1_priority %}
{% else %}
{% set sw = switch2 %}
{% set peer = switch1 %}
{% set uplink_pc = uplink.switch2_port_channel %}
{% set uplink_ifaces = uplink.switch2_interfaces %}
{% set hsrp_priority = hsrp.switch2_priority %}
{% endif %}

! ============================================================
! {{ sw.hostname }} — Generated Configuration
! Nexus 93240YC-FX2 | VPC Switch {{ switch_num }} of 2
! VPC Domain: {{ vpc_domain }}
! Generated by: github.com/kloroxx/lab-documentation
! ============================================================

! ---- GLOBAL FEATURES ----
feature vpc
feature hsrp
feature lacp
feature lldp
feature nxapi

! ---- HOSTNAME & DOMAIN ----
hostname {{ sw.hostname }}
ip domain-name {{ domain_name }}

! ---- SYSTEM MTU ----
system jumbomtu {{ mtu.system }}

! ---- USER ACCOUNT ----
username {{ admin_username }} role network-admin

! ---- NTP ----
{% for ntp in ntp_servers %}
ntp server {{ ntp.ip }}{% if ntp.prefer %} prefer{% endif %}

{% endfor %}
ntp source-interface {{ ntp_source_interface }}

! ---- SNMP ----
snmp-server community {{ snmp.community_ro }} ro
snmp-server community {{ snmp.community_rw }} rw
snmp-server location {{ snmp.location }}
snmp-server contact {{ snmp.contact }}
snmp-server host {{ snmp.trap_host }} traps version 2c {{ snmp.community_ro }}

! ---- TACACS+ ----
tacacs-server key {{ tacacs.key }}
{% for tac in tacacs.servers %}
tacacs-server host {{ tac.ip }}
{% endfor %}
ip tacacs source-interface {{ tacacs.source_interface }}
aaa group server tacacs+ TACACS-GROUP
{% for tac in tacacs.servers %}
  server {{ tac.ip }}
{% endfor %}
  source-interface {{ tacacs.source_interface }}
  use-vrf {{ tacacs.vrf }}
aaa authentication login default group TACACS-GROUP local
aaa authorization commands default group TACACS-GROUP local
aaa accounting default group TACACS-GROUP

! ---- LOGGING ----
{% for log in logging.servers %}
logging server {{ log.ip }} {{ logging.level }} use-vrf management
{% endfor %}
logging source-interface {{ logging.source_interface }}
logging timestamp milliseconds

! ---- VLANs ----
{% for vlan in vlans %}
vlan {{ vlan.id }}
  name {{ vlan.name }}
{% endfor %}

! ---- VPC DOMAIN ----
vpc domain {{ vpc_domain }}
  peer-keepalive destination {{ peer.mgmt_ip }} source {{ sw.mgmt_ip }} vrf {{ vpc_keepalive.vrf }}
  peer-gateway
  auto-recovery
  delay restore 150
  ip arp synchronize

! ---- VPC PEER LINK ----
interface port-channel{{ peer_link.port_channel }}
  description VPC-PEER-LINK
  switchport
  switchport mode trunk
  switchport trunk allowed vlan {{ uplink.allowed_vlans }}
  spanning-tree port type network
  vpc peer-link
  no shutdown

{% for iface in peer_link.interfaces %}
interface {{ iface }}
  description VPC-PEER-LINK-MEMBER
  switchport
  switchport mode trunk
  channel-group {{ peer_link.port_channel }} mode active
  no shutdown

{% endfor %}

! ---- UPLINK TO 7K CORE ----
interface port-channel{{ uplink_pc }}
  description UPLINK-TO-7K-CORE
  switchport
  switchport mode trunk
  switchport trunk allowed vlan {{ uplink.allowed_vlans }}
  spanning-tree port type network
  vpc {{ uplink_pc }}
  no shutdown

{% for iface in uplink_ifaces %}
interface {{ iface }}
  description UPLINK-TO-7K-CORE-MEMBER
  switchport
  switchport mode trunk
  channel-group {{ uplink_pc }} mode active
  no shutdown

{% endfor %}

! ---- FEX UNITS ----
{% for fex in fex_units %}
fex {{ fex.fex_id }}
  pinning max-links 1
  description {{ fex.description }}
  type {{ fex.fex_type }}

interface port-channel{{ fex.port_channel }}
  description {{ fex.description }}
  switchport
  switchport mode fex-fabric
  fex associate {{ fex.fex_id }}
  vpc {{ fex.port_channel }}
  no shutdown

{% if switch_num == 1 %}
interface {{ fex.switch1_interface }}
{% else %}
interface {{ fex.switch2_interface }}
{% endif %}
  description {{ fex.description }}-UPLINK
  switchport
  switchport mode fex-fabric
  fex associate {{ fex.fex_id }}
  channel-group {{ fex.port_channel }} mode on
  no shutdown

{% endfor %}

! ---- SVIs WITH HSRP ----
{% for svi in svis %}
{% if switch_num == 1 %}
{% set svi_ip = svi.switch1_ip %}
{% else %}
{% set svi_ip = svi.switch2_ip %}
{% endif %}
interface Vlan{{ svi.vlan_id }}
  description VLAN{{ svi.vlan_id }}-SVI
  no shutdown
  mtu {{ mtu.layer3 }}
  ip address {{ svi_ip }}
  hsrp version {{ hsrp.version }}
  hsrp {{ svi.hsrp_group }}
    priority {{ hsrp_priority }}
    {% if hsrp.preempt %}preempt{% endif %}

    ip {{ svi.hsrp_vip }}

{% endfor %}

! ---- MANAGEMENT ----
interface mgmt0
  description OOB-MANAGEMENT
  vrf member management
  ip address {{ sw.mgmt_ip }}/{{ sw.mgmt_mask | ipaddr('prefix') }}
  no shutdown

vrf context management
  ip route 0.0.0.0/0 {{ sw.mgmt_gateway }}

! ---- LOOPBACK ----
interface loopback0
  description ROUTER-ID
  ip address {{ sw.loopback0_ip }}/32

! ---- END ----
